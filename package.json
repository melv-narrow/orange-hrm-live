{
  "name": "orange-hrm-live",
  "version": "1.0.0",
  "description": "Playwright + TypeScript regression suite for the OrangeHRM live demo",
  "private": true,
  "scripts": {
    "clean:reports": "node -e \"const fs=require('node:fs'); ['allure-history','allure-report','allure-results','playwright-report','test-results'].forEach((path)=>fs.rmSync(path,{ recursive:true, force:true }));\"",
    "test": "npm run clean:reports && playwright test",
    "test:headed": "npm run clean:reports && playwright test --headed",
    "test:public": "npm run clean:reports && playwright test --project=public-chromium",
    "test:app": "npm run clean:reports && playwright test --project=authenticated-chromium",
    "report": "playwright show-report",
    "allure:generate": "npx allure-commandline generate allure-results --clean -o allure-report",
    "allure:open": "npm run allure:generate && npx allure-commandline open allure-report",
    "allure:serve": "npx allure-commandline serve allure-results"
  },
  "keywords": [
    "playwright",
    "typescript",
    "orangehrm",
    "e2e"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0"
  }
}
